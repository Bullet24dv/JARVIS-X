FROM python:3.12-slim-bookworm

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY agents/ ./agents/
COPY backend/core/agents/ ./backend/core/agents/
COPY backend/core/llm_router.py ./backend/core/
COPY backend/core/memory/ ./backend/core/memory/
COPY backend/config.py ./backend/

CMD ["python", "-m", "agents.agent_manager"]